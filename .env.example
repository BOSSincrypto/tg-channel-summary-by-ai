# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Owner Telegram ID (numeric, e.g. 123456789)
OWNER_TELEGRAM_ID=

# OpenRouter API Key (from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Custom AI providers (JSON array, optional)
# Format: [{"name":"my-provider","base_url":"https://api.example.com/v1","api_key":"sk-...","default_model":"model-name"}]
CUSTOM_PROVIDERS=[]

# Digest time (HH:MM, Moscow timezone by default)
DIGEST_TIME=21:00

# Timezone (IANA format)
TIMEZONE=Europe/Moscow

# HTTP server port (for health check + WebApp)
PORT=8080

# SQLite database path
DB_PATH=/data/bot.db

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Request delay between channel fetches (seconds)
FETCH_DELAY_MS=2500

# Max retries for failed channel fetches
MAX_RETRIES=3

# Max posts per channel per digest (prevents runaway context)
MAX_POSTS_PER_CHANNEL=100

# Days to retain scraped posts before periodic cleanup
POST_RETENTION_DAYS=90
