# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Owner Telegram ID (numeric, e.g. 123456789)
OWNER_TELEGRAM_ID=

# OpenRouter API Key (from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Stable key used to encrypt provider API keys at rest. Set this in production
# and keep it unchanged across BOT_TOKEN rotations.
PROVIDER_ENCRYPTION_KEY=

# One-deployment migration aid only: set to the previous provider encryption
# key while moving existing rows to PROVIDER_ENCRYPTION_KEY, then remove it.
# PROVIDER_ENCRYPTION_KEY_PREVIOUS=

# HTTPS URL for the Telegram WebApp settings page
WEBAPP_URL=https://tg-channel-summary.fly.dev/webapp/

# HTTP server port (for health check + WebApp)
PORT=8080

# SQLite database path
DB_PATH=/data/bot.db

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Max retries for failed channel fetches
MAX_RETRIES=3

# Max posts per channel per digest (prevents runaway context; default 50)
MAX_POSTS_PER_CHANNEL=50

# Days to retain scraped posts before periodic cleanup
POST_RETENTION_DAYS=90

# Legacy compatibility inputs below are parsed for older deployments but are
# not active runtime settings. Configure providers and per-group digest time
# and timezone in the authenticated WebApp; the parser uses its own request
# pacing. Do not add these as production settings:
# CUSTOM_PROVIDERS=[]
# DIGEST_TIME=21:00
# TIMEZONE=Europe/Moscow
# FETCH_DELAY_MS=2500
